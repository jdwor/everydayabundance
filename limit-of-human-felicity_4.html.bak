];

const state = { activeId: ITEMS[0].id };
const byId = new Map(ITEMS.map((item, index) => [item.id, { ...item, index }]));
const buttons = new Map();
const railButtons = new Map();
const steps = new Map();

const hotspots = document.getElementById("hotspots");
const roomFrame = document.querySelector(".room-frame");
const storySection = document.getElementById("story");
const imagePlane = document.getElementById("imagePlane");
const hotspotPlane = document.getElementById("hotspotPlane");
const rail = document.getElementById("rail");
const stepsRoot = document.getElementById("steps");
const ledger = document.getElementById("ledger");
const focusWash = document.getElementById("focusWash");
const activeMini = document.getElementById("activeMini");
const activeSource = document.getElementById("activeSource");
const ROOM_RATIO = 1672 / 941;
let manualNavigationUntil = 0;

const LEDGER_ORDER = [...ITEMS]
  .sort((a, b) => a.availableSort - b.availableSort)
  .map((item) => item.id);

function clamp(value, min, max) {
  return Math.min(max, Math.max(min, value));
}

function updateRoomFocus(item = byId.get(state.activeId)) {
  if (!roomFrame || !imagePlane || !hotspotPlane || !item) return;

  const frame = roomFrame.getBoundingClientRect();
  if (!frame.width || !frame.height) return;

  let baseWidth = frame.height * ROOM_RATIO;
  let baseHeight = frame.height;

  if (baseWidth < frame.width) {
    baseWidth = frame.width;
    baseHeight = baseWidth / ROOM_RATIO;
  }

  const compact = window.matchMedia("(max-width: 1050px)").matches;
  const scale = compact ? 1.02 : (item.zoom || 1.16);
  let tx = (frame.width / 2) - ((item.x / 100) * baseWidth * scale);
  let ty = (frame.height / 2) - ((item.y / 100) * baseHeight * scale);
  const minTx = frame.width - (baseWidth * scale);
  const minTy = frame.height - (baseHeight * scale);
  tx = minTx > 0 ? minTx / 2 : clamp(tx, minTx, 0);
  ty = minTy > 0 ? minTy / 2 : clamp(ty, minTy, 0);

  [imagePlane, hotspotPlane].forEach((layer) => {
    layer.style.width = `${baseWidth}px`;
    layer.style.height = `${baseHeight}px`;
    layer.style.transform = `translate3d(${tx}px, ${ty}px, 0) scale(${scale})`;
  });

  const spotX = (((item.x / 100) * baseWidth * scale) + tx) / frame.width * 100;
  const spotY = (((item.y / 100) * baseHeight * scale) + ty) / frame.height * 100;
  focusWash.style.setProperty("--spot-x", `${clamp(spotX, 0, 100)}%`);
  focusWash.style.setProperty("--spot-y", `${clamp(spotY, 0, 100)}%`);
}

function makeHotspot(item) {
  const button = document.createElement("button");
  button.type = "button";
  button.className = "hotspot";
  button.dataset.id = item.id;
  button.style.setProperty("--x", `${item.x}%`);
  button.style.setProperty("--y", `${item.y}%`);
  button.style.setProperty("--accent", item.color);
  button.setAttribute("aria-label", `${item.object}: ${item.title}`);

  const label = document.createElement("span");
  label.textContent = item.object;
  button.appendChild(label);

  button.addEventListener("click", () => {
    manualNavigationUntil = Date.now() + 1400;
    setActive(item.id);
    steps.get(item.id).scrollIntoView({ behavior: "smooth", block: "center" });
  });
  button.addEventListener("focus", () => setActive(item.id, { passive: true }));
  button.addEventListener("mouseenter", () => setActive(item.id, { passive: true }));

  hotspots.appendChild(button);
  buttons.set(item.id, button);
}

function makeStep(item) {
  const article = document.createElement("article");
  article.className = "step";
  article.dataset.id = item.id;
  article.innerHTML = `
    <h3 class="item-title">${item.title}</h3>
    <blockquote class="quote">${item.quote}</blockquote>
    <p class="source">${item.who}, ${item.year}. ${item.source}</p>
    <p class="context">${item.context}</p>
  `;
  stepsRoot.appendChild(article);
  steps.set(item.id, article);
}

function makeRail(item) {
  const button = document.createElement("button");
  button.type = "button";
  button.className = "rail-button";
  button.dataset.id = item.id;
  button.innerHTML = `<span class="rail-year">${item.year}</span><span class="rail-label">${item.object}</span>`;
  button.addEventListener("click", () => {
    manualNavigationUntil = Date.now() + 1400;
    setActive(item.id);
    steps.get(item.id).scrollIntoView({ behavior: "smooth", block: "center" });
  });
  rail.appendChild(button);
  railButtons.set(item.id, button);
}

function makeLedger(item) {
  const entry = document.createElement("article");
  entry.className = "ledger-item";
  entry.innerHTML = `
    <p class="ledger-kicker">${item.availableYear}</p>
    <h3>${item.object}</h3>
    <p>${item.then}: ${item.context}</p>
  `;
  ledger.appendChild(entry);
}

function setActive(id, options = {}) {
  const item = byId.get(id);
  if (!item) return;
  state.activeId = id;

  activeMini.textContent = item.title;
  activeSource.textContent = `${item.who}, ${item.year}`;
  updateRoomFocus(item);

  buttons.forEach((button, key) => {
    const active = key === id;
    button.classList.toggle("is-active", active);
    button.setAttribute("aria-pressed", active ? "true" : "false");
  });

  railButtons.forEach((button, key) => {
    const active = key === id;
    button.classList.toggle("is-active", active);
    button.setAttribute("aria-current", active ? "true" : "false");
  });

  steps.forEach((step, key) => {
    step.classList.toggle("is-active", key === id);
  });

  if (!options.passive) {
    railButtons.get(id)?.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
  }
}

ITEMS.forEach((item) => {
  makeHotspot(item);
  makeStep(item);
  makeRail(item);
});

LEDGER_ORDER.map((id) => byId.get(id)).filter(Boolean).forEach(makeLedger);

let scrollFrame = 0;

function syncActiveFromScroll() {
  scrollFrame = 0;
  if (storySection) {
    document.body.classList.toggle("is-story-header", storySection.getBoundingClientRect().top <= 18);
  }
  if (Date.now() < manualNavigationUntil) return;

  const readingLine = window.innerHeight * 0.58;
  let candidateId = ITEMS[0].id;
  let candidateTop = -Infinity;

  steps.forEach((step, id) => {
    const anchor = step.querySelector(".quote") || step;
    const top = anchor.getBoundingClientRect().top;
    if (top <= readingLine && top > candidateTop) {
      candidateId = id;
      candidateTop = top;
    }
  });

  if (candidateId !== state.activeId) {
    setActive(candidateId, { passive: true });
  }
}

function queueScrollSync() {
  if (scrollFrame) return;
  scrollFrame = requestAnimationFrame(syncActiveFromScroll);
}

window.addEventListener("scroll", queueScrollSync, { passive: true });
window.addEventListener("resize", () => {
  updateRoomFocus();
  queueScrollSync();
}, { passive: true });

setActive(state.activeId, { passive: true });
queueScrollSync();
</script>
</body>
</html>
